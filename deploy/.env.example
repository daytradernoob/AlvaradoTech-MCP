# AlvaradoTech-MCP — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── TELEGRAM ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_telegram_user_id

# ── INFERENCE MODEL ───────────────────────────────────────
# Track A (on-prem): ollama/mcp-qwen3
# Track B (VPS/cloud): anthropic/claude-haiku-4-5
MCP_PRIMARY_MODEL=anthropic/claude-haiku-4-5

# ── API KEYS ──────────────────────────────────────────────
# Required for Track B (VPS deployment)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Required for Track A (on-prem) — Ollama host
OLLAMA_BASE_URL=http://192.168.0.146:11434

# Optional: web search (Brave Search API)
BRAVE_SEARCH_API_KEY=your_brave_api_key

# ── GATEWAY AUTH ──────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=generate_a_random_64_char_hex_string

# ── NERVE UI (optional) ───────────────────────────────────
NERVE_PASSWORD=your_nerve_ui_password
NERVE_SESSION_SECRET=generate_a_random_32_char_string
