{
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/llama3.2:3b"
      },
      "elevatedDefault": "full",
      "timeoutSeconds": 900,
      "workspace": "/home/rob-alvarado/.openclaw/workspace"
    }
  },
  "tools": {
    "profile": "coding",
    "allow": ["group:runtime", "group:fs"],
    "web": {
      "search": {
        "enabled": true,
        "provider": "brave"
      }
    },
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "telegram": ["YOUR_TELEGRAM_USER_ID"]
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "ollama": {
        "baseUrl": "http://192.168.0.146:11434",
        "apiKey": "ollama-local",
        "api": "ollama",
        "models": [
          {"id": "llama3.2:3b", "name": "llama3.2:3b", "api": "ollama"},
          {"id": "qwen3:8b", "name": "qwen3:8b", "api": "ollama"}
        ]
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "botToken": "YOUR_TELEGRAM_BOT_TOKEN",
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "groupPolicy": "allowlist",
      "streaming": "partial"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowInsecureAuth": true
    },
    "auth": {
      "mode": "token",
      "token": "YOUR_GATEWAY_TOKEN"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send"
      ]
    }
  },
  "plugins": {
    "entries": {
      "brave": {
        "enabled": true,
        "config": {
          "webSearch": {
            "apiKey": "YOUR_BRAVE_API_KEY"
          }
        }
      }
    }
  }
}
